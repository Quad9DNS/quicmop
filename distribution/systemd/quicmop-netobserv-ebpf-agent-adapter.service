[Unit]
Description=Quicmop netobserv eBPF agent adapter
Documentation=https://github.com/Quad9DNS/quicmop
After=network-online.target
Requires=network-online.target

[Service]
ExecStart=/usr/bin/quicmop-netobserv-ebpf-agent-adapter
ExecReload=/bin/kill -HUP $MAINPID
Restart=always

[Install]
WantedBy=multi-user.target
